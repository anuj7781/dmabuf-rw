From 8d4f3479d0269712d889574ecf64001986c956f3 Mon Sep 17 00:00:00 2001
From: Anuj Gupta <anuj1072538@gmail.com>
Date: Tue, 14 Jul 2026 20:41:19 +0530
Subject: [PATCH] debug: trace map-kill, I/O drain, fence-signal, lazy-wake
 decision, and long amdgpu fence stalls

Temporary instrumentation for reproducing the AMDGPU KFD-restore vs.
io_dmabuf resv/fence deadlock. Prior runs with this instrumentation
proved: for a stuck map, "all I/O completed pre task-work" fires but
"fence signalled" never does - every request finishes at the
block-layer level, but the task-work that would drop the last ref and
let the fence signal never runs. This adds one more print to find out
*why* that task-work never runs.

- io_dmabuf: "map killed" - once per map, at kill.
- io_uring/rsrc + io_dmabuf: "all I/O completed pre task-work" - once
  per map, via a separate io_pending counter independent of ->refs.
- io_dmabuf: "fence signalled" - once per map, at dma_fence_signal().
- io_uring/tw + io_dmabuf: "local_work_add" - logs io_uring's own
  lazy-wake decision (io_req_local_work_add(), IORING_SETUP_DEFER_TASKRUN
  path) at the point a dmabuf request's completion task-work is queued
  for an already-killed map: nr_tw (pending work count), nr_tw_prev,
  nr_wait (ctx->cq_wait_nr, the CQE count the waiter is currently
  blocked on), and will_wake (whether wake_up_state() is about to be
  called). wake_up_state() is only called when nr_tw crosses nr_wait -
  if it never does for the request draining the last ref, the waiting
  task is never woken for that specific completion, which would fully
  explain the stall despite the task being alive, schedulable, and
  waking frequently for unrelated reasons.
- amdgpu_sync_wait: "LONG STALL >3s" - once per stalled fence wait.

Debug-only, not for upstream.

Signed-off-by: Anuj Gupta <anuj20.g@samsung.com>
Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c | 30 +++++++++-
 include/linux/io_dmabuf_token.h          | 22 ++++++++
 io_uring/rsrc.c                          |  2 +
 io_uring/rw.c                            |  4 ++
 io_uring/tw.c                            |  7 +++
 lib/io_dmabuf_token.c                    | 70 ++++++++++++++++++++++++
 6 files changed, 132 insertions(+), 3 deletions(-)

diff --git a/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c b/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c
index d6ae9974c952..dd821f71b2a6 100644
--- a/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c
+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c
@@ -462,9 +462,33 @@ int amdgpu_sync_wait(struct amdgpu_sync *sync, bool intr)
 	int i, r;
 
 	hash_for_each_safe(sync->fences, i, tmp, e, node) {
-		r = dma_fence_wait(e->fence, intr);
-		if (r)
-			return r;
+		struct dma_fence *f = e->fence;
+		signed long timeout;
+
+		/* debug only: flag any single fence wait stuck past 3s */
+		timeout = dma_fence_wait_timeout(f, intr, msecs_to_jiffies(3000));
+		if (!timeout) {
+			const char __rcu *drv, *tl;
+
+			rcu_read_lock();
+			drv = dma_fence_driver_name(f);
+			tl = dma_fence_timeline_name(f);
+			pr_info("amdgpu_sync_wait [%s:%d]: LONG STALL >3s on fence ctx=%llu seqno=%llu drv=%s tl=%s owner=%s signaled=%d\n",
+				current->comm, current->pid,
+				(unsigned long long)f->context,
+				(unsigned long long)f->seqno,
+				rcu_dereference(drv), rcu_dereference(tl),
+				amdgpu_sync_get_owner(f) == AMDGPU_FENCE_OWNER_UNDEFINED ?
+					"UNDEFINED" : "other",
+				dma_fence_is_signaled(f));
+			rcu_read_unlock();
+
+			r = dma_fence_wait(f, intr);
+			if (r)
+				return r;
+		} else if (timeout < 0) {
+			return timeout;
+		}
 
 		amdgpu_sync_entry_free(e);
 	}
diff --git a/include/linux/io_dmabuf_token.h b/include/linux/io_dmabuf_token.h
index b94bda684812..5c8f19df602a 100644
--- a/include/linux/io_dmabuf_token.h
+++ b/include/linux/io_dmabuf_token.h
@@ -3,6 +3,7 @@
 #define _LINUX_DMA_TOKEN_H
 
 #include <linux/dma-buf.h>
+#include <linux/sched.h>
 
 struct io_dmabuf_fence;
 struct io_dmabuf_token;
@@ -39,6 +40,16 @@ struct io_dmabuf_map {
 	struct work_struct		release_work;
 	struct io_dmabuf_fence		*fence;
 	struct io_dmabuf_token		*token;
+
+	/*
+	 * debug only: count of requests that have attached to this map and
+	 * not yet reached completion, tracked independently of ->refs so we
+	 * can tell when every I/O has finished at the block-layer level,
+	 * before any task-work runs. Incremented once per new attachment
+	 * (io_import_dmabuf), decremented once per completion
+	 * (io_complete_rw).
+	 */
+	atomic_t			io_pending;
 };
 
 struct io_dmabuf_token {
@@ -53,6 +64,10 @@ struct io_dmabuf_token {
 
 	void					*dev_priv;
 	const struct io_dmabuf_token_dev_ops	*dev_ops;
+
+	/* debug only: registering task, snapshotted for map-kill tracing */
+	pid_t				owner_pid;
+	char				owner_comm[TASK_COMM_LEN];
 };
 
 int io_dmabuf_token_create(struct file *file,
@@ -88,5 +103,12 @@ static inline void io_dmabuf_map_drop(struct io_dmabuf_map *map)
 void io_dmabuf_token_invalidate_mappings(struct io_dmabuf_token *token);
 int io_dmabuf_init_map(struct io_dmabuf_token *token, struct io_dmabuf_map *map);
 
+/* debug only: log genuine I/O completion, independent of task-work */
+void io_dmabuf_trace_io_complete(struct io_dmabuf_map *map);
+/* debug only: log the lazy-wake decision at task-work enqueue time */
+void io_dmabuf_trace_local_work_add(struct io_dmabuf_map *map, unsigned int nr_tw,
+				    unsigned int nr_tw_prev, unsigned int nr_wait,
+				    bool will_wake);
+
 
 #endif
diff --git a/io_uring/rsrc.c b/io_uring/rsrc.c
index 1879c312b881..667093b9c20b 100644
--- a/io_uring/rsrc.c
+++ b/io_uring/rsrc.c
@@ -1274,6 +1274,8 @@ static int io_import_dmabuf(struct io_kiocb *req,
 
 	req->dmabuf_map = map;
 	req->flags |= REQ_F_DROP_DMABUF;
+	/* debug only: track this request against map->io_pending */
+	atomic_inc(&map->io_pending);
 init_iter:
 	iov_iter_dmabuf_map(iter, ddir, map, offset, len);
 	return 0;
diff --git a/io_uring/rw.c b/io_uring/rw.c
index d50da5fa8bb9..27cdbe0a3e1c 100644
--- a/io_uring/rw.c
+++ b/io_uring/rw.c
@@ -12,6 +12,7 @@
 #include <linux/compat.h>
 #include <linux/io_uring/cmd.h>
 #include <linux/indirect_call_wrapper.h>
+#include <linux/io_dmabuf_token.h>
 
 #include <uapi/linux/io_uring.h>
 
@@ -591,6 +592,9 @@ static void io_complete_rw(struct kiocb *kiocb, long res)
 	struct io_rw *rw = container_of(kiocb, struct io_rw, kiocb);
 	struct io_kiocb *req = cmd_to_io_kiocb(rw);
 
+	if (IS_ENABLED(CONFIG_DMABUF_TOKEN) && (req->flags & REQ_F_DROP_DMABUF))
+		io_dmabuf_trace_io_complete(req->dmabuf_map);
+
 	__io_complete_rw_common(req, res);
 	io_req_set_res(req, io_fixup_rw_res(req, res), 0);
 	req->io_task_work.func = io_req_rw_complete;
diff --git a/io_uring/tw.c b/io_uring/tw.c
index fdff81eebc95..236318876263 100644
--- a/io_uring/tw.c
+++ b/io_uring/tw.c
@@ -7,6 +7,7 @@
 #include <linux/sched/signal.h>
 #include <linux/io_uring.h>
 #include <linux/indirect_call_wrapper.h>
+#include <linux/io_dmabuf_token.h>
 
 #include "io_uring.h"
 #include "tctx.h"
@@ -227,6 +228,12 @@ void io_req_local_work_add(struct io_kiocb *req, unsigned flags)
 	}
 
 	nr_wait = atomic_read(&ctx->cq_wait_nr);
+
+	if (IS_ENABLED(CONFIG_DMABUF_TOKEN) && (req->flags & REQ_F_DROP_DMABUF))
+		io_dmabuf_trace_local_work_add(req->dmabuf_map, nr_tw, nr_tw_prev,
+					       nr_wait,
+					       nr_tw >= nr_wait && nr_tw_prev < nr_wait);
+
 	/* not enough or no one is waiting */
 	if (nr_tw < nr_wait)
 		return;
diff --git a/lib/io_dmabuf_token.c b/lib/io_dmabuf_token.c
index 808b5ad33dbc..9a7b5cf714a1 100644
--- a/lib/io_dmabuf_token.c
+++ b/lib/io_dmabuf_token.c
@@ -63,6 +63,9 @@ static void io_dmabuf_map_release_work(struct work_struct *work)
 	 * It should be done before taking the resv lock as someone could be
 	 * waiting for the fence while holding the lock.
 	 */
+	pr_info("io_dmabuf: fence signalled ctx=%llu, seqno=%llu\n",
+		(unsigned long long)fence->base.context,
+		(unsigned long long)fence->base.seqno);
 	dma_fence_signal(&fence->base);
 
 	dma_resv_lock(dmabuf->resv, NULL);
@@ -163,6 +166,69 @@ struct io_dmabuf_map *io_dmabuf_create_map(struct io_dmabuf_token *token)
 	return map;
 }
 
+/* debug only: trace which map/fence/task a kill corresponds to */
+static void io_dmabuf_trace_map_kill(struct io_dmabuf_token *token,
+				     struct io_dmabuf_map *map)
+{
+	struct dma_fence *fence = &map->fence->base;
+
+	pr_info("io_dmabuf: map killed ctx=%llu, seqno=%llu, owner=%s:%d\n",
+		(unsigned long long)fence->context,
+		(unsigned long long)fence->seqno,
+		token->owner_pid ? token->owner_comm : "unknown",
+		token->owner_pid);
+}
+
+/*
+ * debug only: called synchronously from the block-layer completion
+ * callback (io_complete_rw), before any task-work is scheduled. Decrements
+ * map->io_pending, which is incremented once per request attachment in
+ * io_import_dmabuf() - independent of ->refs, which is only decremented
+ * later via task-work.
+ *
+ * Logs exactly once, on the transition to zero for an already-killed
+ * map: "every I/O against this map has finished at the block-layer
+ * level, before task-work". Compare against "fence signalled": if this
+ * fires but that never does, the I/O layer fully drained and task-work
+ * is what never ran - not the I/O.
+ */
+void io_dmabuf_trace_io_complete(struct io_dmabuf_map *map)
+{
+	int remaining = atomic_dec_return(&map->io_pending);
+
+	if (remaining || !percpu_ref_is_dying(&map->refs))
+		return;
+
+	pr_info("io_dmabuf: all I/O completed pre task-work ctx=%llu, seqno=%llu\n",
+		(unsigned long long)map->fence->base.context,
+		(unsigned long long)map->fence->base.seqno);
+}
+EXPORT_SYMBOL_GPL(io_dmabuf_trace_io_complete);
+
+/*
+ * debug only: log the io_uring "lazy wake" decision at task-work enqueue
+ * time (io_req_local_work_add), for a request against an already-killed
+ * (draining) map. Only fires once per map - the first time such a
+ * request's task-work gets queued after the kill, which is normally the
+ * request whose completion is needed to let the map finish draining.
+ * Shows whether wake_up_state() was actually going to be called, so we
+ * can tell "wake was skipped by the lazy-wake threshold" apart from
+ * "wake happened but the task never processed the work".
+ */
+void io_dmabuf_trace_local_work_add(struct io_dmabuf_map *map, unsigned int nr_tw,
+				    unsigned int nr_tw_prev, unsigned int nr_wait,
+				    bool will_wake)
+{
+	if (!percpu_ref_is_dying(&map->refs))
+		return;
+
+	pr_info("io_dmabuf: local_work_add ctx=%llu, seqno=%llu, nr_tw=%u, nr_tw_prev=%u, nr_wait=%u, will_wake=%d\n",
+		(unsigned long long)map->fence->base.context,
+		(unsigned long long)map->fence->base.seqno,
+		nr_tw, nr_tw_prev, nr_wait, will_wake);
+}
+EXPORT_SYMBOL_GPL(io_dmabuf_trace_local_work_add);
+
 static void io_dmabuf_drop_map(struct io_dmabuf_token *token)
 {
 	struct dma_buf *dmabuf = token->dmabuf;
@@ -182,6 +248,7 @@ static void io_dmabuf_drop_map(struct io_dmabuf_token *token)
 		struct dma_fence *fence = &map->fence->base;
 
 		dma_fence_get(fence);
+		io_dmabuf_trace_map_kill(token, map);
 		percpu_ref_kill(&map->refs);
 		dma_fence_wait(fence, false);
 		dma_fence_put(fence);
@@ -194,6 +261,7 @@ static void io_dmabuf_drop_map(struct io_dmabuf_token *token)
 	 * Delay destruction until all inflight requests using the map are
 	 * gone. It'll also signal the fence then.
 	 */
+	io_dmabuf_trace_map_kill(token, map);
 	percpu_ref_kill(&map->refs);
 }
 
@@ -253,6 +321,8 @@ int io_dmabuf_token_create(struct file *file,
 	token->dir = dir;
 	token->dmabuf = dmabuf;
 	refcount_set(&token->refs, 1);
+	token->owner_pid = task_pid_nr(current);
+	get_task_comm(token->owner_comm, current);
 	get_dma_buf(dmabuf);
 
 	ret = file->f_op->create_dmabuf_token(file, token);
-- 
2.43.0

