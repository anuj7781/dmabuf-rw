From d1dff9ebb2fa8e864acbfd0e030fa087757779a1 Mon Sep 17 00:00:00 2001
From: Anuj Gupta <anuj1072538@gmail.com>
Date: Tue, 14 Jul 2026 20:41:19 +0530
Subject: [PATCH] debug: trace dmabuf token map-kill, I/O completion, ref-drop,
 fence-signal, and long amdgpu fence stalls

Temporary instrumentation for reproducing the AMDGPU KFD-restore vs.
io_dmabuf resv/fence deadlock:

- io_dmabuf: log ctx/seqno/owner pid+comm whenever a map's percpu_ref
  is killed (once per map), so a map-kill event can be correlated with
  the fio job that registered it.
- io_uring/rw: log ctx/seqno/completing-task pid+comm at io_complete_rw(),
  before any task-work is scheduled - a genuine I/O completion marker,
  independent of task-work. Fires once per in-flight request draining
  after a kill, not once per map.
- io_uring/rsrc: log ctx/seqno/dropping-task pid+comm whenever a
  per-request map ref is dropped on an already-killed (draining) map
  (io_drop_dmabuf_node). Also once per in-flight request, not once per
  map - only the last one actually drops the count to zero.
- io_dmabuf: log ctx/seqno once, unconditionally, at the point
  dma_fence_signal() is called in io_dmabuf_map_release_work() - the
  one true one-shot "map is fully drained" marker, distinct from the
  per-request ref-drop log above.
- amdgpu_sync_wait: log ctx/seqno/driver/timeline/owner/signalled state
  for any single fence wait that takes longer than 3s, without changing
  wait semantics (falls back to an unbounded wait after logging).

The completion and ref-drop traces are gated on percpu_ref_is_dying() -
steady-state activity on live (non-draining) maps is silent. Unfiltered,
the ref-drop print alone fires on every I/O completion across every
job, floods dmesg, and perturbs completion-path timing enough to stop
the deadlock from reproducing.

Together: "completion" vs "ref dropped" counts for the same ctx/seqno
tell apart "I/O finished but task-work never ran" from "I/O itself
never finished". "fence signalled" (or its absence) is the unambiguous
one-shot answer to whether the map ever fully drained at all.

Debug-only, not for upstream.

Signed-off-by: Anuj Gupta <anuj20.g@samsung.com>
Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c | 30 +++++++++--
 include/linux/io_dmabuf_token.h          | 10 ++++
 io_uring/rsrc.c                          |  1 +
 io_uring/rw.c                            |  4 ++
 lib/io_dmabuf_token.c                    | 64 ++++++++++++++++++++++++
 5 files changed, 106 insertions(+), 3 deletions(-)

diff --git a/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c b/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c
index d6ae9974c952..dd821f71b2a6 100644
--- a/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c
+++ b/drivers/gpu/drm/amd/amdgpu/amdgpu_sync.c
@@ -462,9 +462,33 @@ int amdgpu_sync_wait(struct amdgpu_sync *sync, bool intr)
 	int i, r;
 
 	hash_for_each_safe(sync->fences, i, tmp, e, node) {
-		r = dma_fence_wait(e->fence, intr);
-		if (r)
-			return r;
+		struct dma_fence *f = e->fence;
+		signed long timeout;
+
+		/* debug only: flag any single fence wait stuck past 3s */
+		timeout = dma_fence_wait_timeout(f, intr, msecs_to_jiffies(3000));
+		if (!timeout) {
+			const char __rcu *drv, *tl;
+
+			rcu_read_lock();
+			drv = dma_fence_driver_name(f);
+			tl = dma_fence_timeline_name(f);
+			pr_info("amdgpu_sync_wait [%s:%d]: LONG STALL >3s on fence ctx=%llu seqno=%llu drv=%s tl=%s owner=%s signaled=%d\n",
+				current->comm, current->pid,
+				(unsigned long long)f->context,
+				(unsigned long long)f->seqno,
+				rcu_dereference(drv), rcu_dereference(tl),
+				amdgpu_sync_get_owner(f) == AMDGPU_FENCE_OWNER_UNDEFINED ?
+					"UNDEFINED" : "other",
+				dma_fence_is_signaled(f));
+			rcu_read_unlock();
+
+			r = dma_fence_wait(f, intr);
+			if (r)
+				return r;
+		} else if (timeout < 0) {
+			return timeout;
+		}
 
 		amdgpu_sync_entry_free(e);
 	}
diff --git a/include/linux/io_dmabuf_token.h b/include/linux/io_dmabuf_token.h
index b94bda684812..a1cd25d36c7c 100644
--- a/include/linux/io_dmabuf_token.h
+++ b/include/linux/io_dmabuf_token.h
@@ -3,6 +3,7 @@
 #define _LINUX_DMA_TOKEN_H
 
 #include <linux/dma-buf.h>
+#include <linux/sched.h>
 
 struct io_dmabuf_fence;
 struct io_dmabuf_token;
@@ -53,6 +54,10 @@ struct io_dmabuf_token {
 
 	void					*dev_priv;
 	const struct io_dmabuf_token_dev_ops	*dev_ops;
+
+	/* debug only: registering task, snapshotted for map-kill tracing */
+	pid_t				owner_pid;
+	char				owner_comm[TASK_COMM_LEN];
 };
 
 int io_dmabuf_token_create(struct file *file,
@@ -88,5 +93,10 @@ static inline void io_dmabuf_map_drop(struct io_dmabuf_map *map)
 void io_dmabuf_token_invalidate_mappings(struct io_dmabuf_token *token);
 int io_dmabuf_init_map(struct io_dmabuf_token *token, struct io_dmabuf_map *map);
 
+/* debug only: log when a per-request map ref is actually dropped */
+void io_dmabuf_trace_map_drop(struct io_dmabuf_map *map);
+/* debug only: log genuine I/O completion, independent of task-work */
+void io_dmabuf_trace_io_complete(struct io_dmabuf_map *map);
+
 
 #endif
diff --git a/io_uring/rsrc.c b/io_uring/rsrc.c
index 1879c312b881..56959510eb59 100644
--- a/io_uring/rsrc.c
+++ b/io_uring/rsrc.c
@@ -1239,6 +1239,7 @@ void io_drop_dmabuf_node(struct io_kiocb *req)
 	imu = req->buf_node->buf;
 	if (WARN_ON_ONCE(!(imu->flags & IO_REGBUF_F_DMABUF)))
 		return;
+	io_dmabuf_trace_map_drop(req->dmabuf_map);
 	io_dmabuf_map_drop(req->dmabuf_map);
 }
 
diff --git a/io_uring/rw.c b/io_uring/rw.c
index d50da5fa8bb9..27cdbe0a3e1c 100644
--- a/io_uring/rw.c
+++ b/io_uring/rw.c
@@ -12,6 +12,7 @@
 #include <linux/compat.h>
 #include <linux/io_uring/cmd.h>
 #include <linux/indirect_call_wrapper.h>
+#include <linux/io_dmabuf_token.h>
 
 #include <uapi/linux/io_uring.h>
 
@@ -591,6 +592,9 @@ static void io_complete_rw(struct kiocb *kiocb, long res)
 	struct io_rw *rw = container_of(kiocb, struct io_rw, kiocb);
 	struct io_kiocb *req = cmd_to_io_kiocb(rw);
 
+	if (IS_ENABLED(CONFIG_DMABUF_TOKEN) && (req->flags & REQ_F_DROP_DMABUF))
+		io_dmabuf_trace_io_complete(req->dmabuf_map);
+
 	__io_complete_rw_common(req, res);
 	io_req_set_res(req, io_fixup_rw_res(req, res), 0);
 	req->io_task_work.func = io_req_rw_complete;
diff --git a/lib/io_dmabuf_token.c b/lib/io_dmabuf_token.c
index 808b5ad33dbc..8c2f5588f695 100644
--- a/lib/io_dmabuf_token.c
+++ b/lib/io_dmabuf_token.c
@@ -63,6 +63,9 @@ static void io_dmabuf_map_release_work(struct work_struct *work)
 	 * It should be done before taking the resv lock as someone could be
 	 * waiting for the fence while holding the lock.
 	 */
+	pr_info("io_dmabuf: fence signalled ctx=%llu, seqno=%llu\n",
+		(unsigned long long)fence->base.context,
+		(unsigned long long)fence->base.seqno);
 	dma_fence_signal(&fence->base);
 
 	dma_resv_lock(dmabuf->resv, NULL);
@@ -163,6 +166,63 @@ struct io_dmabuf_map *io_dmabuf_create_map(struct io_dmabuf_token *token)
 	return map;
 }
 
+/* debug only: trace which map/fence/task a kill corresponds to */
+static void io_dmabuf_trace_map_kill(struct io_dmabuf_token *token,
+				     struct io_dmabuf_map *map)
+{
+	struct dma_fence *fence = &map->fence->base;
+
+	pr_info("io_dmabuf: map killed ctx=%llu, seqno=%llu, owner=%s:%d\n",
+		(unsigned long long)fence->context,
+		(unsigned long long)fence->seqno,
+		token->owner_pid ? token->owner_comm : "unknown",
+		token->owner_pid);
+}
+
+/*
+ * debug only: log when a per-request map ref is actually dropped, but only
+ * for maps already killed (draining after invalidation). Steady-state
+ * refcounting on live maps is silent - that path fires on every single I/O
+ * completion and floods dmesg / perturbs timing enough to hide the race.
+ */
+void io_dmabuf_trace_map_drop(struct io_dmabuf_map *map)
+{
+	struct dma_fence *fence;
+
+	if (!percpu_ref_is_dying(&map->refs))
+		return;
+
+	fence = &map->fence->base;
+	pr_info("io_dmabuf: ref dropped ctx=%llu, seqno=%llu, by=%s:%d\n",
+		(unsigned long long)fence->context,
+		(unsigned long long)fence->seqno,
+		current->comm, current->pid);
+}
+EXPORT_SYMBOL_GPL(io_dmabuf_trace_map_drop);
+
+/*
+ * debug only: log genuine I/O completion for a request against this map,
+ * called synchronously from the block-layer completion callback, before
+ * any task-work is scheduled. Compare against "ref dropped" lines for the
+ * same ctx/seqno: if every completion for a draining map is logged here
+ * but the matching "ref dropped" never shows up, the I/O finished and the
+ * task-work-driven ref-drop is the thing that never ran - not the I/O.
+ */
+void io_dmabuf_trace_io_complete(struct io_dmabuf_map *map)
+{
+	struct dma_fence *fence;
+
+	if (!percpu_ref_is_dying(&map->refs))
+		return;
+
+	fence = &map->fence->base;
+	pr_info("io_dmabuf: completion (pre task-work) ctx=%llu, seqno=%llu, by=%s:%d\n",
+		(unsigned long long)fence->context,
+		(unsigned long long)fence->seqno,
+		current->comm, current->pid);
+}
+EXPORT_SYMBOL_GPL(io_dmabuf_trace_io_complete);
+
 static void io_dmabuf_drop_map(struct io_dmabuf_token *token)
 {
 	struct dma_buf *dmabuf = token->dmabuf;
@@ -182,6 +242,7 @@ static void io_dmabuf_drop_map(struct io_dmabuf_token *token)
 		struct dma_fence *fence = &map->fence->base;
 
 		dma_fence_get(fence);
+		io_dmabuf_trace_map_kill(token, map);
 		percpu_ref_kill(&map->refs);
 		dma_fence_wait(fence, false);
 		dma_fence_put(fence);
@@ -194,6 +255,7 @@ static void io_dmabuf_drop_map(struct io_dmabuf_token *token)
 	 * Delay destruction until all inflight requests using the map are
 	 * gone. It'll also signal the fence then.
 	 */
+	io_dmabuf_trace_map_kill(token, map);
 	percpu_ref_kill(&map->refs);
 }
 
@@ -253,6 +315,8 @@ int io_dmabuf_token_create(struct file *file,
 	token->dir = dir;
 	token->dmabuf = dmabuf;
 	refcount_set(&token->refs, 1);
+	token->owner_pid = task_pid_nr(current);
+	get_task_comm(token->owner_comm, current);
 	get_dma_buf(dmabuf);
 
 	ret = file->f_op->create_dmabuf_token(file, token);
-- 
2.43.0

